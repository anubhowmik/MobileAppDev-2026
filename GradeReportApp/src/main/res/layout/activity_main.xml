<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Student Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/name_anupom_bhowmik"
            android:textSize="26sp"
            android:textColor="#0D47A1"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/id_22_49522_3"
            android:textSize="18sp"
            android:textColor="#37474F"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/semester_spring_2026"
            android:textSize="18sp"
            android:textColor="#37474F"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/department_computer_science_amp_engineering"
            android:textSize="18sp"
            android:textColor="#37474F"
            android:textStyle="bold" />

        <!-- Table -->
        <TableLayout
            android:id="@+id/tableLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="*"
            android:layout_marginTop="12dp"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:elevation="2dp">

            <!-- Header -->
            <TableRow android:background="#1565C0">

                <TextView
                    android:text="Subject"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:padding="6dp"/>

                <TextView
                    android:text="Obtained"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:padding="6dp"/>

                <TextView
                    android:text="Total"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:padding="6dp"/>

                <TextView
                    android:text="Grade"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:padding="6dp"/>
            </TableRow>

        </TableLayout>

        <!-- GPA -->
        <TextView
            android:id="@+id/gpaText"
            android:layout_width="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_height="wrap_content"
            android:text="GPA: 0.00"
            android:textColor="#1B5E20"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Input Section -->
        <EditText
            android:id="@+id/subjectName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/enter_subject_name"
            android:backgroundTint="#1565C0"
            android:padding="10dp"/>

        <EditText
            android:id="@+id/obtainedMarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Obtained Marks"
            android:inputType="number"
            android:backgroundTint="#1565C0"
            android:padding="10dp"/>

        <EditText
            android:id="@+id/totalMarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Total Marks"
            android:inputType="number"
            android:backgroundTint="#1565C0"
            android:padding="10dp"/>

        <Button
            android:id="@+id/addBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Subject"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/shareBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Share Report"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"/>

    </LinearLayout>
</ScrollView>